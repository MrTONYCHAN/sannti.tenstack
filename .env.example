VITE_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# Legacy anon / public key (Supabase Dashboard → Settings → API → Legacy API Keys)
VITE_SUPABASE_PUBLISHABLE_KEY=your-legacy-anon-or-public-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
GOOGLE_GENERATIVE_AI_API_KEY=optional-for-ai
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash
# Legacy service_role key — server only, never expose to the browser
SUPABASE_SECRET_KEY=server-only-secret-key-for-demo-login-provisioning
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
DEMO_LOGIN_ENABLED=true
VITE_DEMO_LOGIN_ENABLED=true
# Set true to skip Supabase and use offline login (or auto-fallback when Supabase fails)
VITE_LOCAL_AUTH=true
LOCAL_AUTH=true
